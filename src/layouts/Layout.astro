---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Ivantsov.tech",
	description = "Alex Ivantsov — Father, Operations Manager, SysAdmin, Builder",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=JetBrains+Mono:wght@300;400;500&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="bg-[#0a0d14] text-[#f0eff4] antialiased overflow-x-hidden">
		<!-- Scroll progress bar -->
		<div
			id="scroll-progress"
			class="fixed top-0 left-0 h-[2px] z-[60] bg-gradient-to-r from-cyan-500 to-blue-500"
			style="width: 0%"
		>
		</div>

		<!-- Film-grain noise -->
		<svg
			class="pointer-events-none fixed inset-0 z-[100] h-full w-full opacity-[0.03]"
			aria-hidden="true"
		>
			<filter id="noise">
				<feTurbulence
					type="fractalNoise"
					baseFrequency="0.75"
					numOctaves="4"
					stitchTiles="stitch"
				/>
			</filter>
			<rect width="100%" height="100%" filter="url(#noise)" />
		</svg>

		<slot />

		<script>
			function initScrollProgress() {
				const bar = document.getElementById("scroll-progress");
				if (!bar) return;

				function update() {
					const max =
						document.documentElement.scrollHeight -
						window.innerHeight;
					bar.style.width =
						max > 0
							? Math.min(
									(window.scrollY / max) * 100,
									100
								) + "%"
							: "0%";
				}

				window.addEventListener("scroll", update, {
					passive: true,
				});
				update();
			}

			initScrollProgress();
			document.addEventListener("astro:page-load", initScrollProgress);
		</script>
	</body>
</html>
