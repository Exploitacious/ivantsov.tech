---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Ivantsov.tech",
	description = "Alex Ivantsov — Father, Operations Manager, SysAdmin, Builder",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=JetBrains+Mono:wght@300;400;500&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
	</head>
	<body class="bg-[#0a0d14] text-[#f0eff4] antialiased overflow-x-hidden">
		<!-- Film-grain noise -->
		<svg
			class="pointer-events-none fixed inset-0 z-[100] h-full w-full opacity-[0.03]"
			aria-hidden="true"
		>
			<filter id="noise">
				<feTurbulence
					type="fractalNoise"
					baseFrequency="0.75"
					numOctaves="4"
					stitchTiles="stitch"
				/>
			</filter>
			<rect width="100%" height="100%" filter="url(#noise)" />
		</svg>

		<slot />
	</body>
</html>
